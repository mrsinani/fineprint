{
  "manifest_version": 3,
  "name": "FinePrint - Terms of Service Analyzer",
  "description": "Auto-detect and analyze Terms of Service on any website. Get plain-language summaries and risk scores.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["https://fineprint.dev/*"],
      "js": ["src/content/index.ts"],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://fineprint.dev/*",
    "http://localhost:3001/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://fineprint.dev/*",
      "http://localhost:3001/*"
    ]
  }
}
