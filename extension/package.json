{
  "name": "fineprint-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "zip": "npm run build && node scripts/zip-dist.mjs",
    "extension": "node scripts/replace-build.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.30",
    "@types/chrome": "^0.0.287",
    "typescript": "^5.7.0",
    "vite": "^6.3.1"
  }
}
